# 复制此文件为 .env 并填入真实密钥 (不要提交 .env 到版本库)
# 唯一推理入口：LiteLLM
LITELLM_API_KEY=your_litellm_api_key_here
OPENAI_BASE_URL=https://api.animaseed.com/v1
CHAT_MODEL=deepseek-chat
# true: 不做本地敏感词校验；gemini provider 下强制 BLOCK_NONE
DISABLE_SENSITIVE_CHECK=true
VISION_TO_TEXT_MODEL=gemini-3-flash-preview
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
IMAGE_GENERATION_MODEL=gemini-3-flash-preview

# Langfuse 观测（通过 LiteLLM callback）+ Prompt Management（系统提示词，必填）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
# assets/prompts/langfuse_prompts.json 中要使用的逻辑 key（默认 system）
LANGFUSE_PROMPT_MAP_KEY=system
# 设为 false 时不再从 Langfuse 拉系统提示词（主脑将提示未就绪）
LANGFUSE_SYSTEM_PROMPT_ENABLED=true

# 可选：覆盖 config.yaml 的 app_timezone（IANA），用于注入提示词中的「当前时间」
#APP_TIMEZONE=Asia/Shanghai

VTS_PORT=8001
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
